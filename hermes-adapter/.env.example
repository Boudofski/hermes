# Shared secret — must match RZG_ADAPTER_SECRET in the Next.js app
ADAPTER_SECRET=change-me-in-production

# Set to "true" to return mock responses without running real Hermes
MOCK_MODE=true

# Fallback LLM provider credentials (used when the request doesn't supply its own)
DEFAULT_API_KEY=
DEFAULT_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MAX_TOKENS=3000

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

PORT=8001
