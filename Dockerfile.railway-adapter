FROM python:3.12-slim

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        curl \
    && rm -rf /var/lib/apt/lists/*

COPY . .

RUN pip install --no-cache-dir -e ".[all]" \
    && pip install --no-cache-dir -r hermes-adapter/requirements.txt

EXPOSE 8001

CMD ["sh", "-c", "cd hermes-adapter && uvicorn main:app --host 0.0.0.0 --port ${PORT}"]
