# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database URL for Drizzle (Supabase → Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Hermes Adapter ────────────────────────────────────────────────────────────
# URL where the hermes-adapter FastAPI service is running
RZG_ADAPTER_URL=http://localhost:8001
# Must match ADAPTER_SECRET in hermes-adapter/.env
RZG_ADAPTER_SECRET=change-me-in-production

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
